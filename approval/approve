#!/usr/bin/env bash
set -euo pipefail

APPROVED_DIR="/run/claude-approved"

if [[ $# -eq 0 ]]; then
  echo "Usage: approve '<command>'" >&2
  echo "Example: approve 'bun add react'" >&2
  exit 1
fi

CMD="$*"
mkdir -p "$APPROVED_DIR"
HASH=$(echo -n "$CMD" | sha256sum | cut -d' ' -f1)
echo "$CMD" > "$APPROVED_DIR/$HASH"
echo "✅ Approved: $CMD"
